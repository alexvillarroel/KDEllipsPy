Cell[CellGroupData[{

Cell[BoxData[
    \(uu\)], "Input"],

Cell[BoxData[
    \(UnitStep[
        t]\ \((u\ UnitStep[
              t - 2\ tr] + \(u\ \((t\^2 - 2\ \((t - tr)\)\^2\ UnitStep[t - \
tr])\)\ UnitStep[\(-t\) + 2\ tr]\)\/\(2\ tr\^2\))\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(FullSimplify[
      Sqrt[2*Pi]*FourierTransform[\((uu /. {t \[Rule] tt + tr})\), tt, z], 
      tr > 0]\)], "Input"],

Cell[BoxData[
    \(\@\(2\ \[Pi]\)\ \((\(u\ \((\[Pi]\ DiracDelta[z] + \(\[ImaginaryI]\ \
\[ExponentialE]\^\(\[ImaginaryI]\ tr\ z\) + \((1 + \[ImaginaryI])\)\ \
Interval[{\(-1\), 1}]\)\/z)\)\)\/\@\(2\ \[Pi]\) + \(u\ \((2\ \[ImaginaryI] - \
\[ImaginaryI]\ \((2 + tr\^2\ z\^2)\)\ Cos[tr\ z] + \((2 + 2\ \[ImaginaryI])\)\
\ Interval[{\(-2\), 2}] + z\ \((Interval[{0, 0}] + tr\^2\ z\ Sin[tr\ z])\))\)\
\)\/\(\@\(2\ \[Pi]\)\ tr\^2\ z\^3\))\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(\(\[IndentingNewLine]\)\(zz1\  = \ I*z*t0\)\)\)], "Input"],

Cell[BoxData[
    \(\[ImaginaryI]\ t0\ z\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(term1 = \((1 - Exp[\(-zz1\)])\)/zz1\)], "Input"],

Cell[BoxData[
    \(\(-\(\(\[ImaginaryI]\ \((1 - \[ExponentialE]\^\(\(-\[ImaginaryI]\)\ t0\ \
z\))\)\)\/\(t0\ z\)\)\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(\(zz2\  = \ zz1/2\)\(\[IndentingNewLine]\)
    \)\)], "Input"],

Cell[BoxData[
    \(\(\[ImaginaryI]\ t0\ z\)\/2\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(term2\  = \ Exp[zz2]\)], "Input"],

Cell[BoxData[
    \(\[ExponentialE]\^\(\(\[ImaginaryI]\ t0\ z\)\/2\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(term3\  = \ \(\((term2\  - 1/term2)\)/zz2\)/2\)], "Input"],

Cell[BoxData[
    \(\(-\(\(\[ImaginaryI]\ \((\(-\[ExponentialE]\^\(\(-\(1\/2\)\)\ \
\[ImaginaryI]\ t0\ z\)\) + \[ExponentialE]\^\(\(\[ImaginaryI]\ t0\ \
z\)\/2\))\)\)\/\(t0\ z\)\)\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(transform2 = 
      Expand[FullSimplify[term1*term3/\((zz1/t0)\)]] /. {t0 \[Rule] 
            2*tr}\)], "Input"],

Cell[BoxData[
    \(\(-\(\(\[ImaginaryI]\ \[ExponentialE]\^\(\(-\[ImaginaryI]\)\ tr\ \
z\)\)\/\(2\ tr\^2\ z\^3\)\)\) + \(\[ImaginaryI]\ \[ExponentialE]\^\(\
\[ImaginaryI]\ tr\ z\)\)\/\(4\ tr\^2\ z\^3\) + \(\[ImaginaryI]\ \
\[ExponentialE]\^\(\(-3\)\ \[ImaginaryI]\ tr\ z\)\)\/\(4\ tr\^2\ z\^3\)\)], \
"Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(FullSimplify[Exp[\(-I\)*tr*z]*transform1 - u*transform2]\)], "Input"],

Cell[BoxData[
    \(\(-\(\(\[ImaginaryI]\ \[ExponentialE]\^\(\(-3\)\ \[ImaginaryI]\ tr\ z\)\
\ \((\(-1\) + \[ExponentialE]\^\(\[ImaginaryI]\ tr\ z\))\)\^3\ \((3 + \
\[ExponentialE]\^\(\[ImaginaryI]\ tr\ z\))\)\ u\)\/\(4\ tr\^2\ z\^3\)\)\)\)], \
"Output"]
}, Open  ]],

