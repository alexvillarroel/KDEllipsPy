Cell[BoxData[
    \(transform1 = 
      FullSimplify[
        FullSimplify[
            Integrate[\((uu1 /. {t \[Rule] tt})\)*Exp[\(-I\)*tt*z], {tt, 0, 
                2*tr}], tr > 0] + 
          FullSimplify[u*Exp[\(-I\)*2*tr*z]/\((I*z)\)]]\)], "Input"],

Cell[BoxData[
    \(\(\[ImaginaryI]\ \[ExponentialE]\^\(\(-2\)\ \[ImaginaryI]\ tr\ z\)\ \((\
\(-1\) + \[ExponentialE]\^\(\[ImaginaryI]\ tr\ z\))\)\^2\ u\)\/\(tr\^2\ \
z\^3\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(Plot[
      Abs[transform1 /. {tr \[Rule] 1, u \[Rule] 1}]*z^3, {z, \(-100\)\ , 
        100}]\)], "Input"],

