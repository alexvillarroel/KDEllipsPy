Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
    \(aa = 
      UnitStep[t]*u/tr^2*\((UnitStep[tr - t] - UnitStep[t - tr])\)*
        UnitStep[2*tr - t]\)], "Input"],

Cell[BoxData[
    \(\(u\ UnitStep[t]\ \((\(-UnitStep[t - tr]\) + UnitStep[\(-t\) + tr])\)\ \
UnitStep[\(-t\) + 2\ tr]\)\/tr\^2\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(vv1 = 
      FullSimplify[
        Integrate[\((aa /. {t \[Rule] tt})\), {tt, \(-Infinity\), 
              t}] /. {DiscreteDelta[tr] \[Rule] 0}, {tr > 0, t > 0, 
          t < 2*tr}]\)], "Input"],

Cell[BoxData[
    \(\(u\ \((t + 2\ \((\(-t\) + tr)\)\ UnitStep[t - tr])\)\)\/tr\^2\)], \
"Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(vv\  = \ UnitStep[t]*vv1*UnitStep[2*tr - t]\)], "Input"],

Cell[BoxData[
    \(\(u\ UnitStep[t]\ \((t + 2\ \((\(-t\) + tr)\)\ UnitStep[t - tr])\)\ \
UnitStep[\(-t\) + 2\ tr]\)\/tr\^2\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(uu1\  = \ 
      FullSimplify[
        Integrate[\((vv /. {t \[Rule] tt})\), {tt, \(-Infinity\), 
              t}] /. {DiscreteDelta[tr] \[Rule] 0}, {tr > 0, t > 0, 
          t < 2*tr}]\)], "Input"],

Cell[BoxData[
    \(\(u\ \((t\^2 - 2\ \((t - tr)\)\^2\ UnitStep[t - tr])\)\)\/\(2\ \
tr\^2\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(uu\  = 
      UnitStep[t]*\((uu1*UnitStep[2*tr - t] + 
            u*UnitStep[t - 2*tr])\)\)], "Input"],

Cell[BoxData[
    \(UnitStep[
        t]\ \((u\ UnitStep[
              t - 2\ tr] + \(u\ \((t\^2 - 2\ \((t - tr)\)\^2\ UnitStep[t - \
tr])\)\ UnitStep[\(-t\) + 2\ tr]\)\/\(2\ tr\^2\))\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(\((uu /. {u \[Rule] 1, tr \[Rule] 1})\)\)], "Input"],

Cell[BoxData[
    \(\((UnitStep[\(-2\) + t] + 
          1\/2\ UnitStep[
              2 - t]\ \((t\^2 - 
                2\ \((\(-1\) + t)\)\^2\ UnitStep[\(-1\) + t])\))\)\ UnitStep[
        t]\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(FullSimplify[\((uu /. {u \[Rule] 1, tr \[Rule] 1})\)]\)], "Input"],

Cell[BoxData[
    \(1\/2\ \((\((\(-2\) + t)\)\^2\ UnitStep[\(-2\) + t] - 
          2\ \((\(-1\) + t)\)\^2\ UnitStep[\(-1\) + t] + \((\(-4\) + 
                t)\)\ t\ UnitStep[t])\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(Plot[\((uu1 /. {u \[Rule] 1, tr \[Rule] 1})\), {t, 0, 10}]\)], "Input"],

Cell[GraphicsData["PostScript", "\<\
